import com.google.gson.Gson;
import com.google.gson.GsonBuilder;
import com.google.gson.JsonObject;
import com.google.gson.JsonArray;
import java.io.FileWriter;
import java.io.IOException;
import java.util.*;

public class CatanVisualizer {
    private static final String STATE_FILE = "state.json";
    private Gson gson;
    
    public CatanVisualizer() {
        this.gson = new GsonBuilder().setPrettyPrinting().create();
    }
    
    public void exportGameState(Game game) {
        JsonObject state = new JsonObject();
        
        // Add buildings (settlements and cities)
        JsonArray buildings = new JsonArray();
        for (Settlement settlement : game.getBoard().getSettlements()) {
            JsonObject building = new JsonObject();
            
            // Add coordinates (you need to map your node IDs to coordinates)
            // From the visualizer output, it uses x,y,z coordinates
            double[] coords = getSettlementCoordinates(settlement);
            building.addProperty("x", coords[0]);
            building.addProperty("y", coords[1]);
            building.addProperty("z", coords[2]);
            
            building.addProperty("type", settlement.isCity() ? "city" : "settlement");
            building.addProperty("player", settlement.getOwner().getId());
            buildings.add(building);
        }
        state.add("buildings", buildings);
        
        // Add roads
        JsonArray roads = new JsonArray();
        for (Road road : game.getBoard().getRoads()) {
            JsonObject roadJson = new JsonObject();
            
            // Add start coordinates
            double[] startCoords = getRoadStartCoordinates(road);
            roadJson.addProperty("x1", startCoords[0]);
            roadJson.addProperty("y1", startCoords[1]);
            roadJson.addProperty("z1", startCoords[2]);
            
            // Add end coordinates
            double[] endCoords = getRoadEndCoordinates(road);
            roadJson.addProperty("x2", endCoords[0]);
            roadJson.addProperty("y2", endCoords[1]);
            roadJson.addProperty("z2", endCoords[2]);
            
            roadJson.addProperty("player", road.getOwner().getId());
            roads.add(roadJson);
        }
        state.add("roads", roads);
        
        // Add robber position (if applicable)
        Tile robberTile = game.getBoard().getRobberTile();
        if (robberTile != null) {
            JsonObject robber = new JsonObject();
            double[] robberCoords = getTileCoordinates(robberTile);
            robber.addProperty("x", robberCoords[0]);
            robber.addProperty("y", robberCoords[1]);
            robber.addProperty("z", robberCoords[2]);
            state.add("robber", robber);
        }
        
        // Write to file
        try (FileWriter writer = new FileWriter(STATE_FILE)) {
            gson.toJson(state, writer);
            System.out.println("Game state exported to " + STATE_FILE);
        } catch (IOException e) {
            System.err.println("Error writing state.json: " + e.getMessage());
        }
    }
    
    // Helper methods to map your game coordinates to visualizer coordinates
    private double[] getSettlementCoordinates(Settlement settlement) {
        // You need to implement this based on your coordinate system
        // This should return [x, y, z] coordinates that match the visualizer's expectations
        // From the hex grid in base_map.json, you can derive these
        return new double[]{0.0, 0.0, 0.0}; // Placeholder
    }
    
    private double[] getRoadStartCoordinates(Road road) {
        // Return [x1, y1, z1] for road start
        return new double[]{0.0, 0.0, 0.0}; // Placeholder
    }
    
    private double[] getRoadEndCoordinates(Road road) {
        // Return [x2, y2, z2] for road end
        return new double[]{0.0, 0.0, 0.0}; // Placeholder
    }
    
    private double[] getTileCoordinates(Tile tile) {
        // Return [x, y, z] for tile center (for robber)
        return new double[]{0.0, 0.0, 0.0}; // Placeholder
    }
}